# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Data source (optional override for testing/staging)
# If omitted, app uses the current production sheet ID hardcoded in code.
# SHEET_ID=your-google-sheet-id-here

# Email safety controls:
# - live: normal behavior (send to requested/customer addresses)
# - safe: only allow recipients listed in SAFE_EMAIL_RECIPIENTS
EMAIL_MODE=live
# Comma-separated allowlist used only when EMAIL_MODE=safe
# SAFE_EMAIL_RECIPIENTS=you@example.com,tester@example.com

# Weather API (if needed)
OPENWEATHER_API_KEY=your-weather-api-key-here

# Email Configuration (for Email PDF feature)
# 
# OPTION 1: SendGrid (RECOMMENDED for Render - works reliably)
# Get free API key at: https://sendgrid.com/
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=your-verified-sender@yourdomain.com

# OPTION 2: SMTP (may be blocked on Render free tier)
# For Gmail, use these settings:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password-here

# For Outlook/Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password
