# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Weather API (if needed)
OPENWEATHER_API_KEY=your-weather-api-key-here

# Email/SMTP Configuration (for Email PDF feature)
# For Gmail, use these settings:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# For other email providers, update SMTP_HOST and SMTP_PORT accordingly
# Example for SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Example for Outlook/Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password
