## Safe testing profile
# Copy to `.env` for local/staging testing where production emails must be blocked.

# Optional: point at a non-production Google Sheet for testing.
# SHEET_ID=your-staging-sheet-id

# Enforce recipient allowlist.
EMAIL_MODE=safe
SAFE_EMAIL_RECIPIENTS=your.email@example.com

# Email transport (choose one)
# SENDGRID_API_KEY=your-sendgrid-api-key-here
# FROM_EMAIL=your-verified-sender@yourdomain.com

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password-here
